# because of dotnet, we always build on amd64, and target platforms in cli
# dotnet doesn't support QEMU for building or running. 
# (errors common in arm/v7 32bit) https://github.com/dotnet/dotnet-docker/issues/1537
# https://hub.docker.com/_/microsoft-dotnet
# hadolint ignore=DL3029
# to build for a different platform than your host, use --platform=<platform>
# for example, if you were on Intel (amd64) and wanted to build for ARM, you would use:
# docker buildx build --platform "linux/arm64/v8" .

# build compiles the program for the builder's local platform

# FROM --platform=${BUILDPLATFORM} mcr.microsoft.com/dotnet/sdk:8.0 AS build

# ARG TARGETPLATFORM
# ARG TARGETARCH
# ARG BUILDPLATFORM

# RUN echo "I am running on $BUILDPLATFORM, building for $TARGETPLATFORM"

# WORKDIR /source

# COPY *.csproj .
# RUN dotnet restore -a $TARGETARCH

# COPY . .

# RUN dotnet publish \
#     -c Release \
#     -o /app \
#     -a $TARGETARCH \
#     --self-contained false \
#     --no-restore

# # runtime stage
# FROM mcr.microsoft.com/dotnet/runtime:8.0

# RUN apt-get update && \
#     apt-get upgrade -y && \
#     rm -rf /var/lib/apt/lists/*

# WORKDIR /app

# COPY --from=build /app .

# ENTRYPOINT ["dotnet", "Worker.dll"]


# hadolint ignore=DL3029
FROM --platform=${BUILDPLATFORM} mcr.microsoft.com/dotnet/sdk:8.0 AS build

ARG TARGETPLATFORM
ARG TARGETARCH
ARG BUILDPLATFORM

WORKDIR /source

# Tách riêng để cache lớp layer restore
COPY *.csproj .
RUN dotnet restore -a $TARGETARCH

# Đã có .dockerignore bảo vệ hoàn hảo
COPY . .

RUN dotnet publish \
    -c Release \
    -o /app \
    -a $TARGETARCH \
    --self-contained false \
    --no-restore


# ==============================================================================
# RUNTIME STAGE - Sạch lỗi chạy quyền root
# ==============================================================================
FROM mcr.microsoft.com/dotnet/runtime:8.0

# Gộp lệnh update hệ thống thành 1 layer duy nhất để tối ưu dung lượng
RUN apt-get update && \
    apt-get upgrade -y && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build /app .

# [SonarQube PASSED]: Chuyển sang user đặc quyền thấp, xóa hoàn toàn cảnh báo Root nguy hiểm
USER app

ENTRYPOINT ["dotnet", "Worker.dll"]
